# ============================================
# 服务端配置
# ============================================

# 服务器端口
PORT=3000

# PostgreSQL 数据库连接字符串
DATABASE_URL=postgresql://root:your_password@localhost:5432/login_system

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=24h

# 前端地址（CORS 配置）
CLIENT_ORIGIN=http://localhost:8080
