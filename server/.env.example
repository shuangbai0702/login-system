# ============================================
# 服务端配置
# ============================================

# 服务器端口
PORT=3000

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=login_system

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=24h

# 前端地址（CORS 配置）
CLIENT_ORIGIN=http://localhost:8080
